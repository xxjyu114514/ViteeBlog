# Test your FastAPI endpoints

GET http://127.0.0.1:8000/
Accept: application/json

###

GET http://127.0.0.1:8000/hello/User
Accept: application/json

###


# ==================== 认证相关测试 ====================

# 1. 用户注册
POST http://127.0.0.1:8000/api/v1/auth/register
Content-Type: application/json

{
  "username": "BaoZi",
  "email": "293529819@qq.com",
  "password": "123456"
}

###

# 2. 用户登录（使用正确的凭据）
POST http://127.0.0.1:8000/api/v1/auth/login
Content-Type: application/json

{
  "username": "BaoZi",
  "password": "123456"
}

###

# 3. 用户登录（使用错误的密码 - 测试失败场景）
POST http://127.0.0.1:8000/api/v1/auth/login
Content-Type: application/json

{
  "username": "testuser",
  "password": "wrongpassword"
}

###

# 4. 用户注册（重复用户名 - 测试唯一性约束）
POST http://127.0.0.1:8000/api/v1/auth/register
Content-Type: application/json

{
  "username": "testuser",
  "email": "another@example.com",
  "password": "123456"
}

###

# 5. 用户注册（弱密码测试 - 少于6位）
POST http://127.0.0.1:8000/api/v1/auth/register
Content-Type: application/json

{
  "username": "weakuser",
  "email": "weak@example.com",
  "password": "123"
}

###

# 6. 发送邮箱验证码（需要先注册一个用户）
POST http://127.0.0.1:8000/api/v1/auth/send-code
Content-Type: application/json

{
  "email": "293529819@qq.com"
}

###

# 7. 校验邮箱验证码（将 YOUR_CODE 替换为实际收到的6位验证码）
POST http://127.0.0.1:8000/api/v1/auth/verify-code
Content-Type: application/json

{
  "email": "293529819@qq.com",
  "code": "851688"
}

###

# 8. 发送验证码到未注册的邮箱（测试404错误场景）
POST http://127.0.0.1:8000/api/v1/auth/send-code
Content-Type: application/json

{
  "email": "nonexistent@example.com"
}

###

# 9. 校验错误的验证码（测试400错误场景）
POST http://127.0.0.1:8000/api/v1/auth/verify-code
Content-Type: application/json

{
  "email": "test@example.com",
  "code": "000000"
}