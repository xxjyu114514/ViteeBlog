# ViteeBlog API 测试文件
# 使用方法：在 IntelliJ IDEA / PyCharm 中点击每个请求旁边的运行按钮

GET http://127.0.0.1:8000/
Accept: application/json

###

GET http://127.0.0.1:8000/docs
Accept: text/html

###


# ==================== 认证与用户管理 ====================

# 1. 管理员登录
POST http://127.0.0.1:8000/api/v1/auth/login
Content-Type: application/json

{
  "username": "BaoZi",
  "password": "123456"
}

> {% client.global.set("admin_token", response.body.access_token); %}

###

# 2. 普通用户登录
POST http://127.0.0.1:8000/api/v1/auth/login
Content-Type: application/json

{
  "username": "testuser",
  "password": "123456"
}

> {% client.global.set("user_token", response.body.access_token); %}

###


# ==================== 元数据管理（分类与标签） ====================

# 3. 查看所有分类
GET http://127.0.0.1:8000/api/v1/meta/categories

###

# 4. 管理员创建分类
POST http://127.0.0.1:8000/api/v1/meta/categories
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "name": "Python"
}

> {% client.global.set("category_id", response.body.id); %}

###

# 5. 查看所有标签
GET http://127.0.0.1:8000/api/v1/meta/tags

###

# 6. 普通用户创建标签
POST http://127.0.0.1:8000/api/v1/meta/tags
Authorization: Bearer {{user_token}}
Content-Type: application/json

{
  "name": "Vue"
}

> {% client.global.set("tag_id", response.body.id); %}

###


# ==================== 文章管理核心流程 ====================

# 7. 创建文章（草稿）- 使用 content 字段
# category_id 是可选字段，这里设置为 null 表示不指定分类
POST http://127.0.0.1:8000/api/v1/article/autosave
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "title": "测试文章114",
  "summary": "这是测试摘要514",
  "content": "# 测试文章\n\n这是文章内容，使用 Markdown 格式。\n\n## 副标题\n\n一些测试内容...",
  "category_id": null,
  "tag_ids": []
}

> {% client.global.set("article_id", response.body.id); %}

###

# 8. 更新文章 - 修改内容和标题（id 必须传入）
POST http://127.0.0.1:8000/api/v1/article/autosave
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "id": {{article_id}},
  "title": "测试文章（已更新）",
  "summary": "更新后的摘要",
  "content": "# 更新后的文章\n\n这是更新后的内容。\n\n## 新章节\n\n添加了新的内容段落。",
  "category_id": null,
  "tag_ids": []
}


###

# 9. 获取文章详情（返回 Article 对象，包含所有字段包括审核信息）
GET http://127.0.0.1:8000/api/v1/article/{{article_id}}

###

# 10. 我的文章列表（新版分页接口）
GET http://127.0.0.1:8000/api/v1/article/my/list?page=1&size=10
Authorization: Bearer {{admin_token}}

###

# 11. 公开文章列表（新版分页接口，支持分类筛选）
GET http://127.0.0.1:8000/api/v1/article/public/list?page=1&size=10

###

# 12. 管理员发布文章（免审直发）
PUT http://127.0.0.1:8000/api/v1/article/{{article_id}}/publish
Authorization: Bearer {{admin_token}}

###


# ==================== 普通用户提交流程 ====================

# 13. 普通用户创建文章 - 使用 content 字段
# category_id 是可选字段，这里设置为 null 表示不指定分类
POST http://127.0.0.1:8000/api/v1/article/autosave
Authorization: Bearer {{user_token}}
Content-Type: application/json

{
  "title": "普通用户的文章",
  "summary": "需要审核的文章",
  "content": "# 普通用户文章\n\n这是一篇需要审核的文章内容。\n\n## 正文\n\n详细内容在这里...",
  "category_id": null,
  "tag_ids": []
}

> {% client.global.set("user_article_id", response.body.id); %}

###

# 14. 普通用户提交审核
PUT http://127.0.0.1:8000/api/v1/article/{{user_article_id}}/publish
Authorization: Bearer {{user_token}}

###

# 15. 普通用户撤回审核
POST http://127.0.0.1:8000/api/v1/article/{{user_article_id}}/withdraw
Authorization: Bearer {{user_token}}

###


# ==================== 管理员审核流程 ====================

# 16. 查看待审核文章列表
GET http://127.0.0.1:8000/api/v1/article/admin/pending
Authorization: Bearer {{admin_token}}

###

# 17. 管理员审核通过（注意：需要先执行第146-166行创建并提交文章）
# 审核接口使用 POST 方法，传递 pass_audit 和 remark 参数
POST http://127.0.0.1:8000/api/v1/article/admin/articles/{{user_article_id}}/review
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "pass_audit": true,
  "remark": null
}

###

# 18. 管理员审核驳回（需要先重新提交）
# 先让普通用户再次提交
PUT http://127.0.0.1:8000/api/v1/article/{{user_article_id}}/publish
Authorization: Bearer {{user_token}}

###

# 然后管理员驳回（驳回时必须填写 remark）
POST http://127.0.0.1:8000/api/v1/article/admin/articles/{{user_article_id}}/review
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "pass_audit": false,
  "remark": "内容需要进一步完善"
}

###


# ==================== 回收站操作 ====================

# 19. 软删除文章
DELETE http://127.0.0.1:8000/api/v1/article/{{article_id}}
Authorization: Bearer {{admin_token}}

###

# 20. 恢复文章
POST http://127.0.0.1:8000/api/v1/article/{{article_id}}/restore
Authorization: Bearer {{admin_token}}

###

# 21. 硬删除（彻底删除）
DELETE http://127.0.0.1:8000/api/v1/article/{{article_id}}/hard
Authorization: Bearer {{admin_token}}

###

# 22. 管理员全站列表（默认不显示已删除文章）
GET http://127.0.0.1:8000/api/v1/article/admin/all-articles?page=1&size=10&show_deleted=false
Authorization: Bearer {{admin_token}}

###

# 23. 管理员全站列表（显示已删除文章）
GET http://127.0.0.1:8000/api/v1/article/admin/all-articles?page=1&size=10&show_deleted=true
Authorization: Bearer {{admin_token}}

###


# ==================== 评论管理核心流程 ====================

# 24. 普通用户发表评论
POST http://127.0.0.1:8000/api/v1/comments/articles/{{article_id}}/comments
Authorization: Bearer {{user_token}}
Content-Type: application/json

{
  "content": "这是一篇很棒的文章！学到了很多知识。",
  "parent_id": null
}

> {% client.global.set("comment_id", response.body.id); %}

###

# 25. 回复评论（二级评论）
POST http://127.0.0.1:8000/api/v1/comments/articles/{{article_id}}/comments
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "content": "谢谢你的支持！很高兴能帮到你。",
  "parent_id": {{comment_id}}
}

> {% client.global.set("reply_id", response.body.id); %}

###

# 26. 获取文章的所有评论
GET http://127.0.0.1:8000/api/v1/comments/articles/{{article_id}}/comments

###

# 27. 用户删除自己的评论
DELETE http://127.0.0.1:8000/api/v1/comments/{{comment_id}}
Authorization: Bearer {{user_token}}

###

# 28. 管理员删除任意评论
DELETE http://127.0.0.1:8000/api/v1/comments/{{reply_id}}
Authorization: Bearer {{admin_token}}

###

# 29. 举报评论
POST http://127.0.0.1:8000/api/v1/comments/{{comment_id}}/report
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "reason": "评论内容包含不当言论"
}

> {% client.global.set("report_id", response.body.id); %}

###

# 30. 管理员查看待处理举报列表
GET http://127.0.0.1:8000/api/v1/comments/admin/reports
Authorization: Bearer {{admin_token}}

###

# 31. 管理员处理举报（标记为已解决）
PUT http://127.0.0.1:8000/api/v1/comments/admin/reports/{{report_id}}/resolve
Authorization: Bearer {{admin_token}}

###

# 32. 管理员全站评论巡查（分页）
GET http://127.0.0.1:8000/api/v1/comments/admin/comments/all?page=1&size=20
Authorization: Bearer {{admin_token}}

###


# ==================== 完整业务流程测试 ====================

# 33. 创建新文章用于评论测试
POST http://127.0.0.1:8000/api/v1/article/autosave
Authorization: Bearer {{user_token}}
Content-Type: application/json

{
  "title": "评论功能测试文章",
  "summary": "用于测试评论系统的文章",
  "content": "# 评论功能测试\n\n这篇文章专门用来测试评论功能。\n\n## 测试内容\n\n1. 发表评论\n2. 回复评论\n3. 删除评论\n4. 举报评论",
  "category_id": null,
  "tag_ids": []
}

> {% client.global.set("comment_test_article_id", response.body.id); %}

###

# 34. 发布文章（管理员免审直发）
PUT http://127.0.0.1:8000/api/v1/article/{{comment_test_article_id}}/publish
Authorization: Bearer {{admin_token}}

###

# 35. 多用户连续评论测试 - 用户A第一条评论
POST http://127.0.0.1:8000/api/v1/comments/articles/{{comment_test_article_id}}/comments
Authorization: Bearer {{user_token}}
Content-Type: application/json

{
  "content": "沙发！前排支持作者！",
  "parent_id": null
}

###

# 36. 多用户连续评论测试 - 管理员第二条
POST http://127.0.0.1:8000/api/v1/comments/articles/{{comment_test_article_id}}/comments
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "content": "感谢大家的支持，有问题欢迎留言讨论。",
  "parent_id": null
}

> {% client.global.set("admin_comment_id", response.body.id); %}

###

# 37. 嵌套回复测试 - 回复管理员的评论
POST http://127.0.0.1:8000/api/v1/comments/articles/{{comment_test_article_id}}/comments
Authorization: Bearer {{user_token}}
Content-Type: application/json

{
  "content": "管理员说得对，这个博客真的很棒！",
  "parent_id": {{admin_comment_id}}
}

###

# 38. 再次查看评论列表（应该包含所有评论）
GET http://127.0.0.1:8000/api/v1/comments/articles/{{comment_test_article_id}}/comments

###



