# Test your FastAPI endpoints

GET http://127.0.0.1:8000/
Accept: application/json

###

GET http://127.0.0.1:8000/hello/User
Accept: application/json

###


# ==================== 认证与用户管理 ====================

# 1. 博主登录
POST http://127.0.0.1:8000/api/v1/auth/login
Content-Type: application/json

{
  "username": "BaoZi",
  "password": "123456"
}

> {% client.global.set("admin_token", response.body.access_token); %}

###

# 2. 普通用户登录
POST http://127.0.0.1:8000/api/v1/auth/login
Content-Type: application/json

{
  "username": "testuser",
  "password": "123456"
}

> {% client.global.set("user_token", response.body.access_token); %}

###

# 3. 管理员调整用户权限（示例：将用户升级为管理员）
PUT http://127.0.0.1:8000/api/v1/article/admin/users/1/role
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "new_role": "admin"
}

###


# ==================== 文章管理核心流程 ====================

# 4. 创建文章（草稿）
POST http://127.0.0.1:8000/api/v1/article/autosave
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "title": "测试文章",
  "content": "# Hello\n\n这是测试内容",
  "category_id": null,
  "tag_ids": []
}

> {% client.global.set("article_id", response.body.article_id); %}

###

# 5. 更新文章
POST http://127.0.0.1:8000/api/v1/article/autosave
Authorization: Bearer {{admin_token}}
Content-Type: application/json

{
  "title": "测试文章（已更新）",
  "content": "# Hello\n\n更新后的内容",
  "article_id": {{article_id}},
  "category_id": null,
  "tag_ids": []
}

###

# 6. 查看详情
GET http://127.0.0.1:8000/api/v1/article/{{article_id}}

###

# 7. 管理员审核文章
PUT http://127.0.0.1:8000/api/v1/article/admin/articles/{{article_id}}/audit
Authorization: Bearer {{admin_token}}

###

# 8. 发布文章
PUT http://127.0.0.1:8000/api/v1/article/{{article_id}}/publish
Authorization: Bearer {{admin_token}}

###

# 9. 公开列表（分页）
GET http://127.0.0.1:8000/api/v1/article/list/public?page=1&size=10

###

# 10. 我的文章列表（分页）
GET http://127.0.0.1:8000/api/v1/article/user/my-articles?page=1&size=10
Authorization: Bearer {{admin_token}}

###

# 11. 管理员全站文章（分页）
GET http://127.0.0.1:8000/api/v1/article/admin/all-articles?page=1&size=20
Authorization: Bearer {{admin_token}}

###

# ==================== 回收站操作 ====================

# 12. 软删除
DELETE http://127.0.0.1:8000/api/v1/article/{{article_id}}
Authorization: Bearer {{admin_token}}

###

# 13. 恢复文章
POST http://127.0.0.1:8000/api/v1/article/{{article_id}}/restore
Authorization: Bearer {{admin_token}}

###

# 14. 再次删除并硬删除
DELETE http://127.0.0.1:8000/api/v1/article/{{article_id}}
Authorization: Bearer {{admin_token}}

###

DELETE http://127.0.0.1:8000/api/v1/article/{{article_id}}/hard
Authorization: Bearer {{admin_token}}

###


