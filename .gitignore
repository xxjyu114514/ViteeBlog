# ==========================================
# 后端 (FastAPI / Python) 过滤规则
# ==========================================

# 忽略虚拟环境和依赖
venv/
.venv/
env/
ENV/
virtualenv/
.pyenv/

# Python 字节码与缓存
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.pyre/

# 环境变量配置文件 (包含密钥，绝对不能上传)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Python 包管理
*.egg-info/
.installed.cfg
*.egg
build/
dist/
sdist/
wheels/
pip-wheel-metadata/
pip-delete-this-directory.txt

# ==========================================
# 前端 (Vue.js / Node) 过滤规则
# ==========================================

# 忽略依赖库
node_modules/
jspm_packages/
bower_components/

# 编译产物和构建输出
dist/
dist-ssr/
out/
.nuxt/
.next/
.cache/
.temp/
.tmp/

# Vite 相关缓存
.vite/

# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================
# 编辑器与系统文件
# ==========================================

# IDEs 和编辑器
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.sublime-project
.sublime-workspace

# 系统文件
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# 其他临时文件
*.tmp
*.bak
*.orig
*.log